#
# ~/.bashrc
#

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

alias ls='ls --color=auto'
alias grep='grep --color=auto'
# PS1='[\u@\h \W]\$ '

PROMPT_COMMAND='
PS1_CMD1=$(git branch --show-current 2>/dev/null)
PS1_CMD1=${PS1_CMD1:+($PS1_CMD1)}
'
PS1='\[\e[92;1m\]╭\[\e[96m\]\u\[\e[32m\] \[\e[0;92m\]>\[\e[0m\] \[\e[96m\]\w\[\e[34;1m\] \[\e[95m\]${PS1_CMD1}\n\[\e[92m\]╰\[\e[96m\]\$\[\e[0m\] \[\e]0;\w @ \h\a\]'

shopt -s autocd
export HISTCONTROL=ignoreboth:erasedups

# personal alias
alias ncf='nvim ~/.config/nvim/'
alias launch='setsid "$@" >/dev/null 2>&1'
alias op='launch xdg-open "$@"'

# Tell Bash to use command-name completion for 'launch'
if [ -n "$BASH_VERSION" ]; then
    complete -F _command launch
fi

# zoxide
eval "$(zoxide init bash)"
alias cd="z"

# fzf
eval "$(fzf --bash)"

# yazi
function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
	yazi "$@" --cwd-file="$tmp"
	if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
		builtin cd -- "$cwd"
	fi
	rm -f -- "$tmp"
}

# openfoam
function openfoam() {
	source /opt/OpenFOAM/OpenFOAM-v2512/etc/bashrc
}
